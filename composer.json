{
    "name": "xnoire666/db-diff",
    "description": "Laravel artisan command that diffs two MySQL databases and generates SQL files for the missing tables, views, columns, and mismatched column properties.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "mysql", "database", "schema", "sync", "diff", "artisan"],
    "authors": [
        {
            "name": "rickyx12",
            "email": "aizekrysler@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Xnoire666\\DbDiff\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xnoire666\\DbDiff\\DbDiffServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
